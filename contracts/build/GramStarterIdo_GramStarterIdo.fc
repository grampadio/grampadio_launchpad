    ;; Receive SuperWithdrawTon message
    if (op == 3686087575) {
        var $msg'amount = in_msg~load_varuint16();
        var $msg'destination = in_msg~load_msg_addr();
        throw_unless(42986, ( equal_slices_bits(__tact_context_get_sender(), $self'superAdmin) ));
        throw_unless(23376, ($Context$_get_value(__tact_context_get()) >= 10000000));
        throw_unless(21780, ($msg'amount > 0));
        throw_unless(39053, (($global_myBalance() - $Context$_get_value(__tact_context_get())) >= ($msg'amount + $self'tonReserve)));
        $global_message($MessageParameters$_constructor_to_value_bounce($msg'destination, $msg'amount, false));
        $GramStarterIdo$_contract_store(($self'owner, $self'superAdmin, $self'adminBlocked, $self'tonReserve, $self'deploymentId, $self'usdtJettonMaster, $self'saleTokenJettonMaster, $self'usdtJettonWallet, $self'saleTokenJettonWallet, $self'jettonWalletsConfigured, $self'usdtDecimals, $self'softCap, $self'hardCap, $self'minBuy, $self'maxBuy, $self'tokenPriceMicroUsdt, $self'saleTokenUnit, $self'tgeBasisPoints, $self'cliffDuration, $self'monthlyVestingPeriods, $self'distributionStartedAt, $self'saleTokenRequired, $self'raised, $self'saleTokenDeposited, $self'saleTokenClaimed, $self'usdtRefunded, $self'idoStage, $self'failedReason, $self'upvotes, $self'downvotes, $self'participantCount, $self'claimsProcessed, $self'refundsProcessed, $self'remainingSaleTokensWithdrawn, $self'raisedUsdtWithdrawn, $self'nextTransferQueryId, $self'votes, $self'contributions, $self'allocations, $self'claimedAllocations, $self'claimed, $self'refunded, $self'isParticipant, $self'pendingTransferKind, $self'pendingTransferUser, $self'pendingTransferAmount, $self'pendingTransferAllocation, $self'rejectedUsdtCredits));
        return ();
    }
    
    ;; Receive FundContractTon message
    if (op == 1879568762) {
        var $msg = empty_tuple();
        throw_unless(56230, ($Context$_get_value(__tact_context_get()) > 0));
        $GramStarterIdo$_contract_store(($self'owner, $self'superAdmin, $self'adminBlocked, $self'tonReserve, $self'deploymentId, $self'usdtJettonMaster, $self'saleTokenJettonMaster, $self'usdtJettonWallet, $self'saleTokenJettonWallet, $self'jettonWalletsConfigured, $self'usdtDecimals, $self'softCap, $self'hardCap, $self'minBuy, $self'maxBuy, $self'tokenPriceMicroUsdt, $self'saleTokenUnit, $self'tgeBasisPoints, $self'cliffDuration, $self'monthlyVestingPeriods, $self'distributionStartedAt, $self'saleTokenRequired, $self'raised, $self'saleTokenDeposited, $self'saleTokenClaimed, $self'usdtRefunded, $self'idoStage, $self'failedReason, $self'upvotes, $self'downvotes, $self'participantCount, $self'claimsProcessed, $self'refundsProcessed, $self'remainingSaleTokensWithdrawn, $self'raisedUsdtWithdrawn, $self'nextTransferQueryId, $self'votes, $self'contributions, $self'allocations, $self'claimedAllocations, $self'claimed, $self'refunded, $self'isParticipant, $self'pendingTransferKind, $self'pendingTransferUser, $self'pendingTransferAmount, $self'pendingTransferAllocation, $self'rejectedUsdtCredits));
        return ();
    }
    
    ;; Throw if not handled
    throw(130);
}
